{
  "modelVersion": "6.1.0",
  "dependencies": {
  },
  "execution": {
    "analyze": "normal",
    "daemon": true,
    "incremental": true,
    "parallel": true,
    "typeCheck": false
  },
  "logging": {
    "level": "info"
  },
  "debugging": {
    "stacktrace": false
  },
  "nodeOptions": {
    "maxOldSpaceSize": 8192,
    "exposeGC": true
  }
}
